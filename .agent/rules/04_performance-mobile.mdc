### Ví dụ ĐÚNG

```csharp
public class CountdownTimer : MonoBehaviour
{
    [SerializeField] private TextMeshProUGUI txtTime;

    private static readonly WaitForSecondsRealtime Wait1s = new WaitForSecondsRealtime(1f);
    private Coroutine _countdownCoroutine;

    public void StartCountdown(float seconds)
    {
        if (_countdownCoroutine != null)
            StopCoroutine(_countdownCoroutine);
        _countdownCoroutine = StartCoroutine(CountdownRoutine(seconds));
    }

    private IEnumerator CountdownRoutine(float seconds)
    {
        while (seconds > 0)
        {
            txtTime.text = $"{seconds:F0}";
            yield return Wait1s;
            seconds -= 1f;
        }
        txtTime.text = "0";
    }

    private void OnDisable()
    {
        StopAllCoroutines();
        _countdownCoroutine = null;
    }
}
```

### Ví dụ SAI

```csharp
public class CountdownTimer : MonoBehaviour
{
    public Text txtTime; // Dùng legacy Text thay vì TMP
    private float timeLeft = 60f;

    void Update() // Dùng Update cho countdown
    {
        timeLeft -= Time.deltaTime;
        txtTime.text = "Time: " + timeLeft.ToString("F0"); // String alloc mỗi frame
        
        if (timeLeft <= 0)
        {
            // Spawn effect mỗi khi hết giờ
            Instantiate(effectPrefab, transform.position, Quaternion.identity);
            timeLeft = 60f;
        }

        // LINQ trong Update
        var items = FindObjectsOfType<Item>().Where(i => i.IsActive).ToList();
    }
}
```
