### Ví dụ ĐÚNG

```csharp
// Cần swap ads provider → interface hợp lý
namespace DreamyHarvest.Services
{
    public interface IAdsService
    {
        void ShowBanner();
        void ShowInterstitial(System.Action onComplete, System.Action onFail);
        void ShowRewarded(System.Action<bool> onResult);
        bool IsRewardedReady { get; }
    }

    // Implementation cho AppLovin MAX
    public class MaxAdsService : GameManager, IAdsService
    {
        public void ShowBanner() { /* MAX SDK call */ }
        public void ShowInterstitial(System.Action onComplete, System.Action onFail) { /* ... */ }
        public void ShowRewarded(System.Action<bool> onResult) { /* ... */ }
        public bool IsRewardedReady => MaxSdk.IsRewardedAdReady(adUnitId);
    }
}
```

### Ví dụ SAI

```csharp
// Wrapper 1:1, không thêm value nào
public interface IDataController
{
    void SaveData(bool immediate);
    void LoadData();
    GameData CurrentGameData { get; }
}

// DataController đã là duy nhất, interface chỉ thêm file
public class DataController : GameManager, IDataController
{
    // Mọi method chỉ forward 1:1 → vô nghĩa
}
```
